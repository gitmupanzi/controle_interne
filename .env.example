# Copier uniquement les variables nécessaires dans un fichier .env local non versionné.
# Ne jamais déposer de vrais identifiants dans ce fichier d'exemple.
VISION_SQL_SERVER=serveur-sql.exemple.local
VISION_SQL_DATABASE=BB_VISION_PRO
VISION_SQL_DRIVER=ODBC Driver 18 for SQL Server
VISION_SQL_TRUSTED_CONNECTION=true
VISION_SQL_ENCRYPT=true
VISION_SQL_TRUST_SERVER_CERTIFICATE=false
VISION_SQL_TIMEOUT_SECONDS=15

# Pour une authentification SQL, désactiver VISION_SQL_TRUSTED_CONNECTION et
# définir localement VISION_SQL_USERNAME et VISION_SQL_PASSWORD.

